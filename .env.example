DATABASE_URL=postgresql+psycopg://scholarpulse:scholarpulse@localhost:5432/scholarpulse
DATA_DIR=data
ARXIV_BASE_URL=http://export.arxiv.org/api/query
ARXIV_PAGE_SIZE=200
ARXIV_DELAY_SECONDS=3.0
ARXIV_OVERLAP_HOURS=48
ARXIV_MAX_RETRIES=5
TAXONOMY_DEFAULT=cs,stat,physics
EMBEDDING_MODEL_NAME=BAAI/bge-m3
