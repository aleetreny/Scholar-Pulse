EMBEDDING_DIMENSION=1024
EMBEDDING_SHARD_SIZE=2000
LATEST_WINDOW_DAYS=7
RANDOM_SEED=42
METRICS_KNN_K=10
MAP_SAMPLE_POINTS=150000
MAP_VIEWPORT_CAP=20000
MAP_DENSITY_BINS=160
MAP_UMAP_NEIGHBORS=30
MAP_UMAP_MIN_DIST=0.05
SIMILARITY_PCA_DIM=256
SIMILARITY_HNSW_M=16
SIMILARITY_HNSW_EF_CONSTRUCTION=200
SIMILARITY_HNSW_EF_SEARCH=80
SIMILARITY_CANDIDATE_K=200
SIMILARITY_TOP_K=20
ENRICHMENT_BATCH_SIZE=200
ENRICHMENT_TIMEOUT_SECONDS=30
PREFECT_API_URL=http://localhost:4200/api
LOG_LEVEL=INFO
